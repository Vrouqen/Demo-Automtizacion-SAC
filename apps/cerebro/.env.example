# MongoDB (obligatorio)
# (Mongo Atlas o, tras la migración, la instancia en AWS — ver docs/MIGRACION_MONGO_AWS.md)
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?appName=MiApp
MONGODB_DB=sac
MONGODB_COLLECTION_COLEGIOS=colegios
MONGODB_COLLECTION_CONVERSACIONES=conversaciones
MONGODB_COLLECTION_ESCALAMIENTOS=escalamientos

# Google AI Studio (obligatorio) - genera la key en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Clave de cifrado de credenciales (obligatorio) - 32 bytes en base64.
# DEBE ser la misma en apps/cerebro y apps/carga-credenciales.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENCIALES_ENC_KEY=

# Agentes digitales de servicio (obligatorio para el escalamiento):
# lista de correos separados por coma. Los casos se reparten en round-robin.
# >> REEMPLAZAR con la lista real de correos de los digitales de servicio <<
AGENTES_DIGITALES=digital1@empresa.com,digital2@empresa.com

# Jira externo (EN STANDBY - dejar en false hasta tener acceso real)
JIRA_HABILITADO=false
JIRA_BASE_URL=
JIRA_PROYECTO=
JIRA_EMAIL=
JIRA_API_TOKEN=
